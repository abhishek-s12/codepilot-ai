# ══════════════════════════════════════════════════════════════════
# CodePilot AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════

# ── LLM Provider (OpenRouter recommended) ─────────────────────────
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-openrouter-api-key
LLM_MODEL=openai/gpt-4o-mini
LLM_APP_NAME=CodePilot AI
LLM_SITE_URL=http://localhost:5173

# ── Database (PostgreSQL) ─────────────────────────────────────────
# WARNING: Change the password below to a secure value.
DATABASE_URL=postgresql://codepilot:CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32@localhost:5435/codepilot
POSTGRES_USER=codepilot
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
POSTGRES_DB=codepilot

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant Vector Store ───────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── S3 / MinIO Object Storage ─────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minio_user
# WARNING: Change the secret key below to a secure value.
S3_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
S3_BUCKET_NAME=codepilot-storage

# ── Authentication (JWT) ──────────────────────────────────────────
# WARNING: Set JWT_SECRET to a secure, long random string.
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── App Settings ──────────────────────────────────────────────────
API_TITLE=CodePilot AI
API_VERSION=1.0.0
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
ALLOW_DEV_SANDBOX_LOGIN=true
ENFORCE_STRICT_AUTH=true

