{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "CodePilot AI — Application Metrics Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"codepilot-backend\"}[5m])) by (method, handler)",
          "legendFormat": "{{method}} {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "HTTP Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{job=\"codepilot-backend\",status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"codepilot-backend\"}[5m]))",
          "legendFormat": "Error Rate"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } }
      }
    },
    {
      "id": 3,
      "title": "Request Latency P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"codepilot-backend\"}[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"codepilot-backend\"}[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"codepilot-backend\"}[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "title": "LLM Token Usage Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(codepilot_ai_llm_tokens_total[5m])",
          "legendFormat": "Tokens/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5,
      "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "codepilot_ai_active_ws_connections",
          "legendFormat": "Active WS"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 100 }] } } }
    },
    {
      "id": 6,
      "title": "Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 * rate(codepilot_ai_cache_hits_total[5m]) / (rate(codepilot_ai_cache_hits_total[5m]) + rate(codepilot_ai_cache_misses_total[5m]))",
          "legendFormat": "Hit Rate"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 50 }, { "color": "green", "value": 80 }] } } }
    },
    {
      "id": 7,
      "title": "Celery Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "codepilot_ai_celery_queue_depth",
          "legendFormat": "{{queue}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 8,
      "title": "Celery Tasks Dispatched",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(codepilot_ai_celery_tasks_total[5m])",
          "legendFormat": "{{queue}} {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 9,
      "title": "Container Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{job=\"docker\"}",
          "legendFormat": ""
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["codepilot", "backend", "celery"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "CodePilot AI — Overview",
  "uid": "codepilot-overview",
  "version": 1
}
